# React Native (Expo) public env vars
# Copy this file to .env and update values for your machine/network.

EXPO_PUBLIC_APP_NAME=FilmGo
EXPO_PUBLIC_APP_ENV=development

# IMPORTANT: must be API server URL reachable from your phone/emulator
# Example (same Wi-Fi): http://192.168.1.10:3000/api/v1
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:3000/api/v1
EXPO_PUBLIC_API_TIMEOUT=15000
